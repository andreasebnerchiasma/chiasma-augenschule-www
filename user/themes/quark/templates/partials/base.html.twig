{% set body_classes = body_class(['header-fixed', 'header-animated', 'header-dark', 'header-transparent', 'sticky-footer']) %}
{% set grid_size = theme_var('grid-size') %}
{% set compress = theme_var('production-mode') ? '.min.css' : '.css' %}
{% use 'blocks/base.html.twig' %}
<!DOCTYPE html>
<html lang="{{ grav.language.getActive ?: grav.config.site.default_lang }}">
<head>
{% block head deferred %}
    <meta charset="utf-8" />
    <title>{% if page.title %}{{ page.title|e('html') }} | {% endif %}{{ site.title|e('html') }}</title>
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    {% include 'partials/metadata.html.twig' %}
    <link rel="icon" type="image/png" href="{{ url('theme://images/favicon.png') }}" />
    <link rel="canonical" href="{{ page.url(true, true) }}" />
{% endblock head %}

{% block stylesheets %}
    {% do assets.addCss('theme://css-compiled/spectre'~compress) %}
    {% if theme_var('spectre.exp') %}{% do assets.addCss('theme://css-compiled/spectre-exp'~compress) %}{% endif %}
    {% if theme_var('spectre.icons') %}{% do assets.addCss('theme://css-compiled/spectre-icons'~compress) %}{% endif %}
    {% do assets.addCss('theme://css-compiled/theme'~compress) %}
    {% do assets.addCss('theme://css/custom.css') %}
    {% do assets.addCss('theme://css/line-awesome.min.css') %}
{% endblock %}

{% block javascripts %}
    {% do assets.addJs('jquery', 101) %}
    {% do assets.addJs('theme://js/jquery.treemenu.js', {group:'bottom'}) %}
    {% do assets.addJs('theme://js/site.js', {group:'bottom'}) %}
{% endblock %}

{% block assets deferred %}
    {{ assets.css()|raw }}
    {{ assets.js()|raw }}
{% endblock %}
</head>
<body id="top" class="{% block body_classes %}{{ body_classes }}{% endblock %}">
<div id="page-wrapper">

    {% block header %}
    <section id="header" class="section">
        <section class="container {{ grid_size }}">
            <nav class="navbar">
                <section class="navbar-section logo">
                    {% include 'partials/logo.html.twig' %}
                </section>
                <section class="navbar-section desktop-menu">
                    <nav class="dropmenu animated">
                    {% block header_navigation %}
                        {% include 'partials/navigation.html.twig' %}
                    {% endblock %}
                    </nav>
                    {% if config.plugins.login.enabled and grav.user.username %}
                        <span class="login-status-wrapper"><i class="fa fa-user"></i> {% include 'partials/login-status.html.twig' ignore missing %}</span>
                    {% endif %}
                </section>
            </nav>
        </section>
    </section>

    {# Legacy Quark toggle — hidden, kept for site.js compatibility #}
    <div style="display:none"><div id="toggle"><span class="top"></span><span class="middle"></span><span class="bottom"></span></div></div>

    {# New hamburger button #}
    <button class="mob-hamburger" id="mob-hamburger" aria-label="Menü öffnen">
        <span></span><span></span><span></span>
    </button>
    {% endblock %}

    {% block hero %}{% endblock %}

    <section id="start">
    {% block body %}
        <section id="body-wrapper" class="section">
            <section class="container {{ grid_size }}">
                {% block messages %}
                    {% include 'partials/messages.html.twig' ignore missing %}
                {% endblock %}
                {{ block('content_surround') }}
            </section>
        </section>
    {% endblock %}
    </section>

</div>

{% block footer %}
    {% include 'partials/footer.html.twig' %}
{% endblock %}

{% block mobile %}
{# Legacy overlay — hidden, kept so site.js doesn't error #}
<div id="overlay" style="display:none!important;position:static!important;"></div>

{# Apple-style slide-in drawer #}
<div id="mob-backdrop"></div>
<div id="mob-drawer">

    <div class="mob-header">
        {% include 'partials/logo.html.twig' with {mobile: true} %}
        <button class="mob-close" id="mob-close" aria-label="Schließen">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"
                 stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                <line x1="16" y1="4" x2="4" y2="16"/>
                <line x1="4" y1="4" x2="16" y2="16"/>
            </svg>
        </button>
    </div>

    <div class="mob-panels">

        {# ── MAIN PANEL ── #}
        <div class="mob-panel active" id="mob-panel-main">
            <nav class="mob-nav">
                {% for p in grav.pages.root.children %}
                    {% if p.visible %}
                        {% set sub = p.children.visible %}
                        {% if sub.count > 0 %}
                            <a href="#" class="mob-link mob-has-sub"
                               data-open="mob-panel-{{ p.slug }}">
                                <span>{{ p.menu }}</span>
                                <span class="mob-chev">›</span>
                            </a>
                        {% else %}
                            <a href="{{ p.url }}" class="mob-link">
                                <span>{{ p.menu }}</span>
                            </a>
                        {% endif %}
                    {% endif %}
                {% endfor %}
            </nav>
        </div>

        {# ── SUB-PANELS ── #}
        {% for p in grav.pages.root.children %}
            {% if p.visible %}
                {% set sub = p.children.visible %}
                {% if sub.count > 0 %}
                    <div class="mob-panel" id="mob-panel-{{ p.slug }}">
                        <button class="mob-back" data-back="mob-panel-main">
                            <span class="mob-back-chev">‹</span> Menü
                        </button>
                        <div class="mob-sub-title">{{ p.menu }}</div>
                        <nav class="mob-nav">
                            {% for child in sub %}
                                <a href="{{ child.url }}" class="mob-link mob-link-sub">
                                    <span>{{ child.menu }}</span>
                                </a>
                            {% endfor %}
                        </nav>
                    </div>
                {% endif %}
            {% endif %}
        {% endfor %}

    </div>{# /.mob-panels #}

    <div class="mob-footer">
        <a href="tel:+491731643429" class="mob-phone">+49 (0) 173 164 3429</a>
        <a href="/kontakt" class="mob-cta">Termin vereinbaren</a>
    </div>

</div>{# /#mob-drawer #}

<script>
(function () {
    var backdrop  = document.getElementById('mob-backdrop');
    var drawer    = document.getElementById('mob-drawer');
    var hamburger = document.getElementById('mob-hamburger');
    var closeBtn  = document.getElementById('mob-close');
    var active    = 'mob-panel-main';

    /* ── helpers ── */
    function openDrawer() {
        drawer.classList.add('open');
        backdrop.classList.add('visible');
        document.body.style.overflow = 'hidden';
        hamburger.classList.add('is-open');
    }
    function closeDrawer() {
        drawer.classList.remove('open');
        backdrop.classList.remove('visible');
        document.body.style.overflow = '';
        hamburger.classList.remove('is-open');
        setTimeout(resetPanels, 420);
    }
    function resetPanels() {
        document.querySelectorAll('.mob-panel').forEach(function (p) {
            p.className = 'mob-panel';
        });
        var main = document.getElementById('mob-panel-main');
        if (main) main.classList.add('active');
        active = 'mob-panel-main';
    }

    /* ── drill-down ── */
    function goForward(targetId) {
        var cur = document.getElementById(active);
        var nxt = document.getElementById(targetId);
        if (!cur || !nxt) return;
        nxt.classList.add('active', 'from-right');
        cur.classList.add('to-left');
        setTimeout(function () {
            cur.classList.remove('active', 'to-left');
            nxt.classList.remove('from-right');
        }, 380);
        active = targetId;
    }
    function goBack(targetId) {
        var cur = document.getElementById(active);
        var prv = document.getElementById(targetId);
        if (!cur || !prv) return;
        prv.classList.add('active', 'from-left');
        cur.classList.add('to-right');
        setTimeout(function () {
            cur.classList.remove('active', 'to-right');
            prv.classList.remove('from-left');
        }, 380);
        active = targetId;
    }

    /* ── events ── */
    hamburger.addEventListener('click', function () {
        drawer.classList.contains('open') ? closeDrawer() : openDrawer();
    });
    if (closeBtn)  closeBtn.addEventListener('click', closeDrawer);
    if (backdrop)  backdrop.addEventListener('click', closeDrawer);

    document.querySelectorAll('[data-open]').forEach(function (el) {
        el.addEventListener('click', function (e) {
            e.preventDefault();
            goForward(this.getAttribute('data-open'));
        });
    });
    document.querySelectorAll('[data-back]').forEach(function (el) {
        el.addEventListener('click', function () {
            goBack(this.getAttribute('data-back'));
        });
    });
})();
</script>
{% endblock %}

{% block bottom %}
    {{ assets.js('bottom')|raw }}
{% endblock %}

</body>
</html>
